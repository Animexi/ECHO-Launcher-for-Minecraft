<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>ECHO Launcher</title>
  <link rel="stylesheet" href="styles.css">
  <link rel="stylesheet" href="dialog.css">
</head>
<body>
  <div class="window">
    <!-- Background Animation -->
    <canvas id="bgCanvas" class="bg-canvas"></canvas>
    <div class="bg-animation">
      <div class="grid-overlay"></div>
    </div>

    <!-- Title Bar -->
    <div class="title-bar">
      <div class="title-bar-left">
        <div class="logo-icon"></div>
        <span class="title">ECHO</span>
      </div>
      <div class="title-bar-right">
        <button class="title-btn minimize-btn" id="minimizeBtn">
          <svg width="12" height="2" viewBox="0 0 12 2">
            <rect width="12" height="2" fill="currentColor"/>
          </svg>
        </button>
        <button class="title-btn close-btn" id="closeBtn">
          <svg width="12" height="12" viewBox="0 0 12 12">
            <path d="M1 1L11 11M11 1L1 11" stroke="currentColor" stroke-width="2"/>
          </svg>
        </button>
      </div>
    </div>

    <!-- Main Content -->
    <div class="content">
      <!-- Tabs -->
      <div class="tabs">
        <button class="tab-btn active" data-tab="play">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
            <path d="M5 3L15 10L5 17V3Z"/>
          </svg>
          <span>Играть</span>
        </button>
        <button class="tab-btn" data-tab="versions">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
            <path d="M3 4H17V6H3V4ZM3 9H17V11H3V9ZM3 14H17V16H3V14Z"/>
          </svg>
          <span>Версии</span>
        </button>
        <button class="tab-btn" data-tab="stats">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
            <path d="M2 18V10H6V18H2ZM8 18V2H12V18H8ZM14 18V6H18V18H14Z"/>
          </svg>
          <span>Статистика</span>
        </button>
        <button class="tab-btn" data-tab="settings">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5">
            <circle cx="10" cy="10" r="3"/>
            <path d="M10 1v2m0 14v2M4.22 4.22l1.42 1.42m8.72 8.72l1.42 1.42M1 10h2m14 0h2M4.22 15.78l1.42-1.42m8.72-8.72l1.42-1.42"/>
          </svg>
          <span>Настройки</span>
        </button>
        <button class="tab-btn" data-tab="files">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
            <path d="M4 2C2.9 2 2 2.9 2 4V16C2 17.1 2.9 18 4 18H16C17.1 18 18 17.1 18 16V8L12 2H4ZM4 4H11V9H16V16H4V4Z"/>
          </svg>
          <span>Файлы</span>
        </button>
      </div>

      <!-- Tab Content -->
      <div class="tab-content active" id="playTab">
        <div class="play-section">
          <div class="user-info">
            <div class="avatar-container">
              <div class="avatar"></div>
              <div class="avatar-glow"></div>
            </div>
            <div class="user-details">
              <h2 class="username" id="displayUsername">Player</h2>
              <p class="user-subtitle">Готов к игре</p>
            </div>
          </div>

          <div class="running-instances" id="runningInstances" style="display: none;">
            <div class="instances-header">
              <span>Запущенные версии:</span>
            </div>
            <div class="instances-list" id="instancesList"></div>
          </div>

          <div class="version-selector">
            <label>Выбранная версия:</label>
            <div style="display: flex; gap: 8px;">
              <select id="versionSelect" class="styled-select" style="flex: 1;">
                <option value="">Загрузка...</option>
              </select>
              <button class="open-instance-btn" id="openInstanceBtn" title="Открыть папку версии">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
                  <path d="M2 3C1.45 3 1 3.45 1 4V12C1 12.55 1.45 13 2 13H14C14.55 13 15 12.55 15 12V5C15 4.45 14.55 4 14 4H7L6 3H2Z"/>
                </svg>
              </button>
              <button class="isolation-toggle-btn" id="isolationBtn" title="Переключить изоляцию">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
                  <path d="M8 2C4.7 2 2 4.7 2 8C2 11.3 4.7 14 8 14C11.3 14 14 11.3 14 8C14 4.7 11.3 2 8 2ZM8 12C5.8 12 4 10.2 4 8C4 5.8 5.8 4 8 4C10.2 4 12 5.8 12 8C12 10.2 10.2 12 8 12Z"/>
                </svg>
              </button>
            </div>
            <div class="isolation-status" id="isolationStatus">
              <span class="isolation-indicator"></span>
              <span class="isolation-text">Общая папка</span>
            </div>
          </div>

          <button class="play-button" id="playBtn">
            <span class="play-button-text">Играть</span>
            <div class="play-button-glow"></div>
          </button>

          <div class="download-progress hidden" id="downloadProgress">
            <div class="progress-info">
              <span id="progressStage">Загрузка...</span>
              <span id="progressPercent">0%</span>
            </div>
            <div class="progress-bar">
              <div class="progress-fill" id="progressFill"></div>
            </div>
          </div>
        </div>
      </div>

      <div class="tab-content" id="versionsTab">
        <div class="versions-section">
          <div class="section-header">
            <h2>Доступные версии</h2>
            <input type="text" id="versionSearch" class="search-input" placeholder="Поиск версий...">
          </div>

          <div class="version-filters">
            <button class="filter-btn active" data-filter="vanilla">Vanilla</button>
            <button class="filter-btn" data-filter="forge">Forge</button>
            <button class="filter-btn" data-filter="neoforge">NeoForge</button>
            <button class="filter-btn" data-filter="fabric">Fabric</button>
            <button class="filter-btn" data-filter="quilt">Quilt</button>
            <button class="filter-btn" data-filter="optifine">OptiFine</button>
            <button class="filter-btn" data-filter="all">Все</button>
          </div>

          <div class="versions-list" id="versionsList">
            <div class="loading-spinner">Загрузка версий...</div>
          </div>
        </div>
      </div>

      <div class="tab-content" id="statsTab">
        <div class="stats-section">
          <h2>Статистика игры</h2>

          <div class="stats-overview">
            <div class="stat-card">
              <div class="stat-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                  <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2" fill="none"/>
                  <path d="M12 6v6l4 2"/>
                </svg>
              </div>
              <div class="stat-info">
                <div class="stat-label">Общее время</div>
                <div class="stat-value" id="totalPlaytime">0 ч 0 м</div>
              </div>
            </div>
            <div class="stat-card">
              <div class="stat-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M5 3L19 12L5 21V3Z"/>
                </svg>
              </div>
              <div class="stat-info">
                <div class="stat-label">Всего запусков</div>
                <div class="stat-value" id="totalLaunches">0</div>
              </div>
            </div>
            <div class="stat-card">
              <div class="stat-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 2L15 8L22 9L17 14L18 22L12 18L6 22L7 14L2 9L9 8L12 2Z"/>
                </svg>
              </div>
              <div class="stat-info">
                <div class="stat-label">Любимая версия</div>
                <div class="stat-value" id="favoriteVersion">-</div>
              </div>
            </div>
          </div>

          <h3>История запусков</h3>
          <div class="launch-history" id="launchHistory">
            <div class="empty-state">История запусков пуста</div>
          </div>

          <h3>Статистика по версиям</h3>
          <div class="version-stats" id="versionStats">
            <div class="empty-state">Нет данных</div>
          </div>
        </div>
      </div>

      <div class="tab-content" id="settingsTab">
        <div class="settings-section">
          <h2>Настройки лаунчера</h2>

          <div class="setting-group">
            <label>
              <span>Информация о системе</span>
              <span class="setting-description">Характеристики вашего ПК</span>
            </label>
            <div class="system-info" id="systemInfo">
              <div class="system-info-loading">Загрузка...</div>
            </div>
          </div>

          <div class="setting-group">
            <label>
              <span>Скин персонажа</span>
              <span class="setting-description">Загрузите PNG изображение 64x64 или 64x32</span>
            </label>
            <div class="skin-upload-container">
              <div class="skin-preview" id="skinPreview">
                <div class="skin-placeholder">Нет скина</div>
              </div>
              <div class="skin-controls">
                <input type="file" id="skinInput" accept=".png" style="display: none;">
                <button class="upload-btn" id="uploadSkinBtn">Загрузить скин</button>
                <button class="upload-btn secondary" id="removeSkinBtn">Удалить</button>
              </div>
            </div>
          </div>

          <div class="setting-group">
            <label for="usernameInput">
              <span>Никнейм</span>
              <span class="setting-description">Ваше имя в игре</span>
            </label>
            <input type="text" id="usernameInput" class="styled-input" placeholder="Введите никнейм" maxlength="16">
          </div>

          <div class="setting-group">
            <label for="memoryInput">
              <span>Выделенная RAM (MB)</span>
              <span class="setting-description">Рекомендуется: 2048-4096 MB</span>
            </label>
            <div class="memory-slider-container">
              <input type="range" id="memorySlider" class="styled-slider" min="512" max="16384" step="256" value="2048">
              <input type="number" id="memoryInput" class="styled-input memory-input" min="512" max="16384" value="2048">
            </div>
          </div>

          <div class="setting-group">
            <label>
              <span>Оптимизация производительности</span>
              <span class="setting-description">JVM аргументы для улучшения FPS</span>
            </label>
            <div class="optimization-options">
              <button class="optimization-btn active" data-profile="balanced">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
                  <circle cx="8" cy="8" r="6"/>
                </svg>
                <span>Сбалансированный</span>
                <div class="optimization-desc">Оптимальные настройки для большинства ПК</div>
              </button>
              <button class="optimization-btn" data-profile="performance">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
                  <path d="M8 2L10 6L14 7L11 10L12 14L8 12L4 14L5 10L2 7L6 6L8 2Z"/>
                </svg>
                <span>Максимум FPS</span>
                <div class="optimization-desc">Агрессивная оптимизация GC, минимум лагов</div>
              </button>
              <button class="optimization-btn" data-profile="potato">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
                  <path d="M3 3H13V13H3V3Z"/>
                </svg>
                <span>Слабый ПК</span>
                <div class="optimization-desc">Консервативные настройки, меньше нагрузка</div>
              </button>
            </div>
          </div>

          <div class="setting-group">
            <label>
              <span>Выбор видеокарты</span>
              <span class="setting-description">Выберите GPU для запуска Minecraft</span>
            </label>
            <div class="gpu-selection" id="gpuSelection">
              <div class="system-info-loading">Загрузка...</div>
            </div>
          </div>

          <div class="setting-group">
            <label>
              <span>Поведение лаунчера при запуске игры</span>
              <span class="setting-description">Что делать с лаунчером после запуска Minecraft</span>
            </label>
            <div class="launcher-behavior-options">
              <button class="behavior-btn active" data-behavior="hide">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
                  <path d="M2 2L14 14M2 14L14 2" stroke="currentColor" stroke-width="2"/>
                </svg>
                <span>Скрыть</span>
              </button>
              <button class="behavior-btn" data-behavior="close">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
                  <path d="M8 2C4.7 2 2 4.7 2 8C2 11.3 4.7 14 8 14C11.3 14 14 11.3 14 8C14 4.7 11.3 2 8 2ZM11 10L10 11L8 9L6 11L5 10L7 8L5 6L6 5L8 7L10 5L11 6L9 8L11 10Z"/>
                </svg>
                <span>Закрыть</span>
              </button>
              <button class="behavior-btn" data-behavior="keep">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
                  <rect x="3" y="3" width="10" height="10" stroke="currentColor" stroke-width="2" fill="none"/>
                </svg>
                <span>Оставить открытым</span>
              </button>
            </div>
          </div>

          <button class="save-button" id="saveSettingsBtn">
            <span>Сохранить настройки</span>
          </button>

          <div class="save-notification hidden" id="saveNotification">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
              <path d="M6 11L2 7L3.5 5.5L6 8L12.5 1.5L14 3L6 11Z"/>
            </svg>
            <span>Настройки сохранены</span>
          </div>
        </div>
      </div>

      <div class="tab-content" id="filesTab">
        <div class="files-section">
          <h2>Файлы Minecraft</h2>

          <div class="file-categories">
            <div class="file-category" id="worldsCategory">
              <div class="category-header">
                <svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
                  <path d="M10 2C5.6 2 2 5.6 2 10C2 14.4 5.6 18 10 18C14.4 18 18 14.4 18 10C18 5.6 14.4 2 10 2ZM10 16C6.7 16 4 13.3 4 10C4 6.7 6.7 4 10 4C13.3 4 16 6.7 16 10C16 13.3 13.3 16 10 16Z"/>
                </svg>
                <h3>Миры</h3>
                <button class="open-folder-btn" data-folder="saves">Открыть папку</button>
              </div>
              <div class="file-list" id="worldsList">
                <div class="loading-spinner">Загрузка...</div>
              </div>
            </div>

            <div class="file-category" id="modsCategory">
              <div class="category-header">
                <svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
                  <path d="M14 2H6C4.9 2 4 2.9 4 4V16C4 17.1 4.9 18 6 18H14C15.1 18 16 17.1 16 16V4C16 2.9 15.1 2 14 2ZM14 16H6V4H14V16Z"/>
                </svg>
                <h3>Моды</h3>
                <button class="open-folder-btn" data-folder="mods">Открыть папку</button>
              </div>
              <div class="file-list" id="modsList">
                <div class="empty-state">Моды не установлены</div>
              </div>
            </div>

            <div class="file-category" id="screenshotsCategory">
              <div class="category-header">
                <svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
                  <path d="M7 5L4 8V16H16V8L13 5H7ZM6 10L8 12L12 8L16 14H4L6 10Z"/>
                </svg>
                <h3>Скриншоты</h3>
                <button class="open-folder-btn" data-folder="screenshots">Открыть папку</button>
              </div>
              <div class="file-list" id="screenshotsList">
                <div class="empty-state">Скриншотов нет</div>
              </div>
            </div>

            <div class="file-category" id="logsCategory">
              <div class="category-header">
                <svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
                  <path d="M3 4H17V6H3V4ZM3 9H17V11H3V9ZM3 14H17V16H3V14Z"/>
                </svg>
                <h3>Логи</h3>
                <button class="open-folder-btn" data-folder="logs">Открыть папку</button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script src="dialog.js"></script>
  <script src="renderer.js"></script>
  <script src="background.js"></script>
</body>
</html>
