{
  "name": "echo-launcher",
  "version": "7.0.0s",
  "description": "ECHO - Custom Minecraft Launcher with beautiful UI and animations",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build-installer": "electron-builder --win nsis",
    "dev": "electron . --dev"
  },
  "keywords": [
    "minecraft",
    "launcher",
    "electron",
    "echo"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "adm-zip": "^0.5.17",
    "axios": "^1.6.2",
    "extract-zip": "^2.0.1",
    "fs-extra": "^11.2.0"
  },
  "build": {
    "appId": "com.echo.minecraft.launcher",
    "productName": "ECHO Launcher",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "icon.png",
      "icon.ico"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "ECHO Launcher",
      "installerIcon": "icon.ico",
      "uninstallerIcon": "icon.ico",
      "installerHeaderIcon": "icon.ico"
    }
  }
}
